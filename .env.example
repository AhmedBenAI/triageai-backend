# ── Required ───────────────────────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# CORS origin:
#   Local dev (npm run dev):   http://localhost:4200
#   Docker Compose:            http://localhost
CORS_ORIGIN=http://localhost:4200

# Max triage requests per minute per IP
RATE_LIMIT_RPM=20

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Frontend port when running via Docker Compose (default 80)
FRONTEND_PORT=80
