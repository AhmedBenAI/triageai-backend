# ── AI Keys (at least one required) ────────────────────────────────────────────
# OpenAI GPT-3.5 Turbo — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude Haiku — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# CORS origin — set to your frontend domain in production
#   Local dev (npm run dev):      http://localhost:4200
#   Same-server Docker Compose:   http://localhost
#   Separate domain deployment:   https://yourdomain.com
CORS_ORIGIN=http://localhost:4200

# Max triage requests per minute per IP
RATE_LIMIT_RPM=20

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Port exposed by docker-compose for the backend (default 3000)
BACKEND_PORT=3000
